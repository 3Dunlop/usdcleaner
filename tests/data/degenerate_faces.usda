#usda 1.0
(
    defaultPrim = "MeshWithDegenerates"
    metersPerUnit = 1.0
    upAxis = "Y"
)

# A mesh with 4 triangles, 2 of which are degenerate (collapsed to lines/points).
# After degenerate removal, should have 2 faces remaining.
def Mesh "MeshWithDegenerates" {
    float3[] points = [
        (0, 0, 0),    # 0
        (1, 0, 0),    # 1
        (0, 1, 0),    # 2
        (1, 1, 0)     # 3
    ]

    int[] faceVertexCounts = [3, 3, 3, 3]

    int[] faceVertexIndices = [
        0, 1, 2,    # Valid triangle
        1, 3, 2,    # Valid triangle
        0, 0, 1,    # DEGENERATE: vertex 0 repeated (line, not triangle)
        2, 2, 2     # DEGENERATE: all same vertex (point, not triangle)
    ]

    uniform token subdivisionScheme = "none"
}
