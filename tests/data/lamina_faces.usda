#usda 1.0
(
    defaultPrim = "MeshWithDuplicates"
    metersPerUnit = 1.0
    upAxis = "Y"
)

# A mesh with 4 triangles, where face 2 is a duplicate of face 0
# (same vertices, different winding order) and face 3 is an exact duplicate of face 1.
# After lamina removal, should have 2 unique faces.
def Mesh "MeshWithDuplicates" {
    float3[] points = [
        (0, 0, 0),    # 0
        (1, 0, 0),    # 1
        (0, 1, 0),    # 2
        (1, 1, 0)     # 3
    ]

    int[] faceVertexCounts = [3, 3, 3, 3]

    int[] faceVertexIndices = [
        0, 1, 2,    # Face 0: original
        1, 3, 2,    # Face 1: original
        2, 1, 0,    # Face 2: DUPLICATE of face 0 (reversed winding)
        1, 3, 2     # Face 3: EXACT duplicate of face 1
    ]

    uniform token subdivisionScheme = "none"
}
